{
  "name": "message-app",
  "private": true,
  "scripts": {
    "dev": "concurrently -n web,api -c green,blue \"npm run dev:web\" \"npm run dev:api\"",
    "dev:web": "npm run dev --prefix web",
    "dev:api": "npm run dev --prefix api",
    "build": "npm run build:web && npm run build:api",
    "build:web": "npm run build --prefix web",
    "build:api": "npm run build --prefix api",
    "start:web": "npm run start --prefix web",
    "start:api": "npm run start --prefix api",
    "test:web": "npm run test --prefix web",
    "test:api": "npm run test --prefix api",
    "typecheck:api": "npm run typecheck --prefix api",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down"
  },
  "devDependencies": {
    "concurrently": "^9.2.0"
  }
}
